<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
 xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 x:Class="BusinessInventory.Views.EditProductPage"
 BackgroundColor="#F7F8FA"
 Title="Edit Item">

    
    <ScrollView>

        <VerticalStackLayout
        Padding="20"
        Spacing="16">

            <Label
            Text="Edit Item"
            FontSize="30"
            FontAttributes="Bold"
            TextColor="#111827" />

            <Frame
            HeightRequest="160"
            BackgroundColor="White"
            BorderColor="#E5E7EB"
            CornerRadius="18">

                <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center">

                    <Label
                    Text="📦"
                    FontSize="40" />

                    <Label
                    Text="Update Product Information"
                    TextColor="#6B7280" />

                </VerticalStackLayout>

            </Frame>

            <Label
            Text="PRODUCT NAME"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Entry
            Text="{Binding Name}"
            TextColor="#111827"
            Placeholder="Product Name" />

            <Label
            Text="SKU / BARCODE"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Entry
            Text="{Binding Barcode}"
            TextColor="#111827"
            Placeholder="Barcode" />

            <Label
            Text="QUANTITY"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Entry
            Keyboard="Numeric"
            Text="{Binding Quantity}"
            TextColor="#111827" />

            <Label
            Text="PRICE"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Entry
            Keyboard="Numeric"
            Text="{Binding Price}"
            TextColor="#111827" />

            <Label
            Text="MINIMUM STOCK"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Entry
            Keyboard="Numeric"
            Text="{Binding MinimumStock}"
            TextColor="#111827" />

            <Label
            Text="DESCRIPTION"
            FontAttributes="Bold"
            TextColor="#374151" />

            <Editor
            HeightRequest="120"
            Text="{Binding Description}"
            TextColor="#111827"
            Placeholder="Description" />

            <Button
            HeightRequest="55"
            CornerRadius="15"
            BackgroundColor="#C1121F"
            TextColor="White"
            FontAttributes="Bold"
            Text="Update Product"
            Command="{Binding UpdateCommand}" />

        </VerticalStackLayout>

    </ScrollView>
    

</ContentPage>
