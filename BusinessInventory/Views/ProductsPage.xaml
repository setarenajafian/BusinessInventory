<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="BusinessInventory.Views.ProductsPage"
    Title="Products">

    <Grid RowDefinitions="Auto,*">

        <!-- Add Product Button -->
        <Button
            Grid.Row="0"
            Margin="10"
            Text="Add Product"
            Clicked="OnAddProductClicked" />

        <!-- Products List -->
        <CollectionView
            Grid.Row="1"
            ItemsSource="{Binding Products}"
            Margin="10">

            <CollectionView.EmptyView>
                <VerticalStackLayout
                    VerticalOptions="Center"
                    HorizontalOptions="Center">

                    <Label
                        Text="No products found"
                        FontSize="18" />

                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                        StrokeThickness="1"
                        Padding="12"
                        Margin="0,0,0,10">

                        <VerticalStackLayout Spacing="6">

                            <Label
                                Text="{Binding Name}"
                                FontSize="20"
                                FontAttributes="Bold" />

                            <Label
                                Text="{Binding Barcode, StringFormat='Barcode: {0}'}" />

                            <Label
                                Text="{Binding Quantity, StringFormat='Quantity: {0}'}" />

                            <Label
                                Text="{Binding Price, StringFormat='Price: {0}'}" />

                            <Label
                                Text="{Binding MinimumStock, StringFormat='Minimum Stock: {0}'}" />

                            <Label
                                Text="⚠ Low Stock"
                                TextColor="OrangeRed"
                                FontAttributes="Bold"
                                IsVisible="{Binding IsLowStock}" />     

                            <Label
                                Text="{Binding Description}" />

                            <HorizontalStackLayout
                                Margin="0,8,0,0"
                                Spacing="10">

                                
                                    <Button
                                        Text="Delete"
                                        Clicked="OnDeleteClicked" />

                                    <Button
                                        Text="Edit"
                                        Clicked="OnEditClicked" />

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>

</ContentPage>