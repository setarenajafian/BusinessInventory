<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
 xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
 xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.Maui.Controls"
 x:Class="BusinessInventory.Views.ProductsPage"
 BackgroundColor="#F7F8FA"
 Title="Inventory">

    
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- Header -->
        <VerticalStackLayout
        Grid.Row="0"
        Padding="20,15"
        Spacing="4">

            <Label
            Text="Inventory"
            FontSize="32"
            FontAttributes="Bold"
            TextColor="#111827"/>

            <Label
            Text="{Binding TotalProducts,StringFormat='Total Products: {0}'}"
            TextColor="#6B7280"/>

            <Label
            Text="{Binding LowStockProducts,StringFormat='Low Stock Items: {0}'}"
            TextColor="#6B7280"/>

            <Label
            Text="{Binding TotalInventoryValue,StringFormat='Inventory Value: {0:C}'}"
            TextColor="#6B7280"/>

        </VerticalStackLayout>

        <!-- Search -->
        <SearchBar
            Grid.Row="1"
            Margin="20,0"
            Placeholder="Search products..."
            PlaceholderColor="#9CA3AF"
            TextColor="#111827"
            Text="{Binding SearchText}" />

        <!-- Add Product -->
        <Button
            Grid.Row="2"
            Margin="20,10"
            HeightRequest="55"
            CornerRadius="14"
            BackgroundColor="#C1121F"
            TextColor="White"
            FontAttributes="Bold"
            Text="+ Add New Item"
            Clicked="OnAddProductClicked" />

        <!-- All Items -->
        <Border
            Grid.Row="3"
            HeightRequest="42"
            Padding="24,0"
            Margin="20,0,0,10"
            BackgroundColor="#C1121F"
            HorizontalOptions="Start">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="21"/>
            </Border.StrokeShape>

            <Label
                HorizontalOptions="Center"
                VerticalOptions="Center"
                Text="All Items"
                FontAttributes="Bold"
                TextColor="White"/>
        </Border>
        
        <!-- Products -->
        <CollectionView
        Grid.Row="3"
        Margin="10"
        ItemsSource="{Binding Products}">

            <CollectionView.EmptyView>
                <VerticalStackLayout
                VerticalOptions="Center"
                HorizontalOptions="Center">

                    <Label
                    Text="No products found"
                    FontSize="18"/>

                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <Border
                    Margin="8"
                    Padding="15"
                    BackgroundColor="White"
                    Stroke="#E5E7EB"
                    StrokeThickness="1">

                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18"/>
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="8">

                            <!-- Product Name -->
                            <Label
                            Text="{Binding Name}"
                            FontSize="22"
                            FontAttributes="Bold"
                            TextColor="#111827"/>

                            <!-- Barcode -->
                            <zxing:BarcodeGeneratorView
                            HeightRequest="70"
                            HorizontalOptions="Center"
                            Value="{Binding Barcode}" />

                            <Label
                            Text="{Binding Barcode}"
                            HorizontalOptions="Center"
                            FontAttributes="Bold"
                            TextColor="#6B7280"/>

                            <!-- Stock Badge -->
                            <Border
                            Padding="10,4"
                            HorizontalOptions="Start"
                            BackgroundColor="{Binding StatusColor}">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="15"/>
                                </Border.StrokeShape>

                                <Label
                                Text="{Binding StockStatus}"
                                TextColor="White"
                                FontSize="12"
                                FontAttributes="Bold"/>
                            </Border>

                            <Label
                            Text="{Binding Quantity,StringFormat='Stock: {0} Units'}"
                            TextColor="#374151"/>

                            <Label
                            Text="{Binding Price,StringFormat='Price: {0}'}"
                            TextColor="#374151"/>

                            <Label
                            Text="{Binding Description}"
                            TextColor="#6B7280"/>

                            <HorizontalStackLayout
                            Margin="0,10,0,0"
                            Spacing="10">

                                <Button
                                Text="Edit"
                                BackgroundColor="#E5E7EB"
                                TextColor="#111827"
                                Clicked="OnEditClicked"/>

                                <Button
                                Text="Delete"
                                BackgroundColor="#C1121F"
                                TextColor="White"
                                Clicked="OnDeleteClicked"/>

                            </HorizontalStackLayout>

                        </VerticalStackLayout>

                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
    

</ContentPage>
