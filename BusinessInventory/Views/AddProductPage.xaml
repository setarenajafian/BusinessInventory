<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BusinessInventory.Views.AddProductPage"
             Title="Add Product">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="10">

            <Entry
                Placeholder="Name"
                Text="{Binding Name}" />

            <Button
                Text="Scan Barcode"
                Clicked="OnScanBarcodeClicked"/>

            <Entry
                Placeholder="Barcode"
                Text="{Binding Barcode}" />

            <Label Text="Price"/>
            <Entry
                Keyboard="Numeric"
                Text="{Binding Price}" />

            <Label Text="Quantity"/>
            <Entry
                Keyboard="Numeric"
                Text="{Binding Quantity}" />

            <Label Text="Minimum Stock"/>
            <Entry
                Keyboard="Numeric"
                Text="{Binding MinimumStock}" />

            <Editor
                HeightRequest="100"
                Placeholder="Description"
                Text="{Binding Description}" />

            <Button
                Command="{Binding SaveCommand}"
                Text="Save Product" />

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>